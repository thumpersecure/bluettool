# BlueTTool environment configuration (used by tooling and deployment wrappers)

# Public app URL used in docs/share defaults
BLUETTOOL_APP_URL=https://thumpersecure.github.io/bluettool/

# Log verbosity for runtime logging controls: debug | info | warn | error
BLUETTOOL_LOG_LEVEL=info

# Optional telemetry hook toggle (future use): true | false
BLUETTOOL_ENABLE_TELEMETRY=false

# Maximum accepted import payload size in bytes
BLUETTOOL_MAX_IMPORT_BYTES=1048576
